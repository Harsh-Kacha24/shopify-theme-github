<div id="verify-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:9999; align-items:center; justify-content:center;">
  <div style="background:#ffffff; max-width:480px; width:90%; border-radius:12px; padding:32px; position:relative; max-height:90vh; overflow-y:auto;">
    
    <button id="close-verify-popup" style="position:absolute; top:16px; right:16px; background:none; border:none; font-size:20px; cursor:pointer; color:inherit;">✕</button>

    <h2 style="text-align:center; font-size:20px; font-weight:500; margin-bottom:8px;">Account verification request</h2>
    <p style="text-align:center; font-size:13px; color:#6b6b6b; margin-bottom:4px;">Fill in the form below to request verification.</p>
    <p style="text-align:center; font-size:13px; color:#6b6b6b; margin-bottom:24px;">Once approved, your account will have access to professional products.</p>
    <p style="text-align:center; font-size:13px; margin-bottom:24px;">And, don't worry, it's free.</p>

    <div id="verify-form-wrap">
      <div style="margin-bottom:16px;">
        <label style="font-size:13px; display:block; margin-bottom:6px;">Name*</label>
        <input id="vf-name" type="text" placeholder="Jenny Xu" style="width:100%; padding:10px 12px; border:1px solid #e0dbd5; border-radius:6px; font-size:14px; box-sizing:border-box;">
      </div>
      <div style="margin-bottom:16px;">
        <label style="font-size:13px; display:block; margin-bottom:6px;">Phone number</label>
        <input id="vf-phone" type="tel" placeholder="450-973-2999" style="width:100%; padding:10px 12px; border:1px solid #e0dbd5; border-radius:6px; font-size:14px; box-sizing:border-box;">
      </div>
      <div style="margin-bottom:16px;">
        <label style="font-size:13px; display:block; margin-bottom:6px;">E-mail*</label>
        <input id="vf-email" type="email" placeholder="jenny@liere.ca" style="width:100%; padding:10px 12px; border:1px solid #e0dbd5; border-radius:6px; font-size:14px; box-sizing:border-box;">
      </div>
      <div style="margin-bottom:16px;">
        <label style="font-size:13px; display:block; margin-bottom:6px;">Profession*</label>
        <select id="vf-profession" style="width:100%; padding:10px 12px; border:1px solid #e0dbd5; border-radius:6px; font-size:14px; box-sizing:border-box; background:white;">
          <option value="">Choose an option</option>
          <option value="Acupuncture">Acupuncture</option>
          <option value="Massotherapist">Massotherapist</option>
          <option value="Physiotherapist">Physiotherapist</option>
          <option value="Other">Other: please specify</option>
        </select>
      </div>
      <div id="vf-other-wrap" style="margin-bottom:16px; display:none;">
        <label style="font-size:13px; display:block; margin-bottom:6px;">Please specify your profession*</label>
        <input id="vf-other" type="text" placeholder="Your profession" style="width:100%; padding:10px 12px; border:1px solid #e0dbd5; border-radius:6px; font-size:14px; box-sizing:border-box;">
      </div>
      <div style="margin-bottom:16px;">
        <label style="font-size:13px; display:block; margin-bottom:6px;">Official license number*</label>
        <input id="vf-license" type="text" placeholder="123-456-789" style="width:100%; padding:10px 12px; border:1px solid #e0dbd5; border-radius:6px; font-size:14px; box-sizing:border-box;">
      </div>
      <div style="margin-bottom:24px;">
        <label style="font-size:13px; display:block; margin-bottom:6px;">License expiry date*</label>
        <input id="vf-expiry" type="date" style="width:100%; padding:10px 12px; border:1px solid #e0dbd5; border-radius:6px; font-size:14px; box-sizing:border-box;">
      </div>
      <p id="vf-error" style="color:#c0392b; font-size:13px; margin-bottom:12px; display:none;"></p>
      <div style="text-align:center;">
        <button id="vf-submit" style="background:#E8A020; color:white; border:none; padding:12px 40px; border-radius:6px; font-size:14px; cursor:pointer; font-weight:500;">Submit</button>
      </div>
    </div>

    <div id="verify-success-wrap" style="display:none; text-align:center; padding:16px 0;">
      <p style="font-size:14px; margin-bottom:16px;">Your request has been submitted.<br>You will receive an email with next steps shortly.</p>
      <button id="vf-submitted-btn" style="background:none; border:1px solid #E8A020; color:#E8A020; padding:10px 32px; border-radius:20px; font-size:14px; cursor:default;">Submitted</button>
    </div>

  </div>
</div>

<script>
(function() {
  const overlay = document.getElementById('verify-overlay');
  const formWrap = document.getElementById('verify-form-wrap');
  const successWrap = document.getElementById('verify-success-wrap');
  const profSelect = document.getElementById('vf-profession');
  const otherWrap = document.getElementById('vf-other-wrap');
  const errorMsg = document.getElementById('vf-error');

  function openPopup() {
    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function closePopup() {
    overlay.style.display = 'none';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('#open-verify-popup').forEach(btn => {
    btn.addEventListener('click', openPopup);
  });
  document.getElementById('close-verify-popup').addEventListener('click', closePopup);
  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closePopup();
  });

  profSelect.addEventListener('change', function() {
    otherWrap.style.display = this.value === 'Other' ? 'block' : 'none';
  });

  document.getElementById('vf-submit').addEventListener('click', function() {
    const name = document.getElementById('vf-name').value.trim();
    const email = document.getElementById('vf-email').value.trim();
    const profession = profSelect.value;
    const other = document.getElementById('vf-other').value.trim();
    const license = document.getElementById('vf-license').value.trim();
    const expiry = document.getElementById('vf-expiry').value;

    if (!name || !email || !profession || !license || !expiry) {
      errorMsg.textContent = 'Please fill in all required fields.';
      errorMsg.style.display = 'block';
      return;
    }
    if (profession === 'Other' && !other) {
      errorMsg.textContent = 'Please specify your profession.';
      errorMsg.style.display = 'block';
      return;
    }
    errorMsg.style.display = 'none';

    const finalProfession = profession === 'Other' ? other : profession;
    const phone = document.getElementById('vf-phone').value.trim();
    const note = `VERIFICATION REQUEST\nName: ${name}\nPhone: ${phone}\nEmail: ${email}\nProfession: ${finalProfession}\nLicense: ${license}\nExpiry: ${expiry}`;

    fetch('/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({
        form_type: 'contact',
        utf8: '✓',
        'contact[email]': email,
        'contact[name]': name,
        'contact[body]': note
      })
    }).then(function() {
      formWrap.style.display = 'none';
      successWrap.style.display = 'block';
    }).catch(function() {
      errorMsg.textContent = 'Something went wrong. Please try again.';
      errorMsg.style.display = 'block';
    });
  });
})();
</script>